  <name>NS-CMSIS-NN</name>
  <description>heliaCORE NN - Ambiq's optimized fork of Arm CMSIS-NN, tuned for the Apollo family of ultra-low-power SoCs.</description>
  <vendor>Ambiq</vendor>
  <license>LICENSE</license>
  <licenseSets>
    <licenseSet id="Apache-2.0" default="true">
      <license name="LICENSES/Apache-2.0.txt" title="Apache 2.0 open-source license" spdx="Apache-2.0"/>
    </licenseSet>
    <licenseSet id="Ambiq-Apollo-SDK" gating="true">
      <license name="LICENSE" title="Ambiq Apollo SDK License" url="https://github.com/AmbiqAI/ns-cmsis-nn/blob/main/LICENSE"/>
    </licenseSet>
  </licenseSets>
  <url>https://github.com/AmbiqAI/ns-cmsis-nn/releases/latest/download/</url>
  <repository type="git">https://github.com/AmbiqAI/ns-cmsis-nn</repository>

  <releases>
    <release version="0.0.0">
      Active development
    </release>
  </releases>

  <!-- conditions are dependency rules that can apply to a component or an individual file -->
