    <!-- heliaCORE NN — Prebuilt variant: link Ambiq's vendored per-arch
         libns-cmsis-nn.a instead of compiling sources. One <file> entry per
         supported core; CMSIS-Pack pickers (Keil/CMSIS-Toolbox) resolve the
         right archive via the Dcore + Tcompiler conditions above. -->
    <component Cclass="Machine Learning" Cgroup="NN Lib" Csub="heliaCORE" Cvariant="Prebuilt" Cvendor="Ambiq" Cversion="7.28.0" condition="CMSIS-NN"> <!-- x-release-please-version -->
      <description>heliaCORE NN — Ambiq's prebuilt GCC archive for Cortex-M0/M0+/M4/M55.</description>
      <files>
        <file category="doc"    name="Documentation/html/index.html"/>
        <file category="header" name="Include/arm_nn_types.h"/>
        <file category="header" name="Include/arm_nnfunctions.h"/>
        <file category="header" name="Include/arm_nnsupportfunctions.h"/>
        <file category="header" name="Include/arm_nn_tables.h"/>
        <file category="header" name="Include/arm_nn_math_types.h"/>
        <file category="header" name="Include/arm_nnfunctions_flt.h"/>
        <file category="header" name="Include/arm_nnsupportfunctions_flt.h"/>
        <file category="header" name="Include/arm_nn_types_flt.h"/>
        <file category="header" name="Include/arm_nn_math_types_flt.h"/>

        <file category="library" condition="ARMv6-M GCC"        name="lib/cortex-m0/libns-cmsis-nn.a"/>
        <file category="library" condition="ARMv6-M+ GCC"       name="lib/cortex-m0/libns-cmsis-nn.a"/>
        <file category="library" condition="ARMv7E-M GCC"       name="lib/cortex-m4/libns-cmsis-nn.a"/>
        <file category="library" condition="ARMv8.1-M MVE GCC"  name="lib/cortex-m55/libns-cmsis-nn.a"/>
      </files>
    </component>
  </components>
</package>
