<?xml version="1.0" encoding="UTF-8"?>

<package schemaVersion="1.7.36" xmlns:xs="http://www.w3.org/2001/XMLSchema-instance" xs:noNamespaceSchemaLocation="https://raw.githubusercontent.com/Open-CMSIS-Pack/Open-CMSIS-Pack-Spec/v1.7.36/schema/PACK.xsd">
  <name>NS-CMSIS-NN</name>
  <description>heliaCORE NN - Ambiq's optimized fork of Arm CMSIS-NN, tuned for the Apollo family of ultra-low-power SoCs.</description>
  <vendor>Ambiq</vendor>
  <license>LICENSE</license>
  <licenseSets>
    <licenseSet id="Apache-2.0" default="true">
      <license name="LICENSES/Apache-2.0.txt" title="Apache 2.0 open-source license" spdx="Apache-2.0"/>
    </licenseSet>
    <licenseSet id="Ambiq-Apollo-SDK" gating="true">
      <license name="LICENSE" title="Ambiq Apollo SDK License" url="https://github.com/AmbiqAI/ns-cmsis-nn/blob/main/LICENSE"/>
    </licenseSet>
  </licenseSets>
  <url>https://github.com/AmbiqAI/ns-cmsis-nn/releases/latest/download/</url>
  <repository type="git">https://github.com/AmbiqAI/ns-cmsis-nn</repository>

  <releases>
    <release version="7.28.0"> <!-- x-release-please-version -->
      Active development
    </release>
  </releases>

  <!-- conditions are dependency rules that can apply to a component or an individual file -->
  <conditions>
    <!-- CMSIS-NN -->
    <condition id="CMSIS-NN">
      <description>No additional components required for CMSIS-NN</description>
    </condition>

    <!--
      Per-architecture conditions guarding the prebuilt .a files.
      Tcompiler is GCC across all three because this pack vendors a
      single GNU Arm Embedded build per arch. Multi-toolchain coverage
      tracks under issue #177.
    -->
    <condition id="ARMv6-M GCC">
      <description>ARMv6-M (Cortex-M0/M0+/M1) built with GCC.</description>
      <require Dcore="Cortex-M0"/>
      <require Tcompiler="GCC"/>
    </condition>
    <condition id="ARMv6-M+ GCC">
      <description>ARMv6-M+ (Cortex-M0+) built with GCC.</description>
      <require Dcore="Cortex-M0+"/>
      <require Tcompiler="GCC"/>
    </condition>
    <condition id="ARMv7E-M GCC">
      <description>ARMv7E-M (Cortex-M4 with FPU) built with GCC.</description>
      <require Dcore="Cortex-M4"/>
      <require Tcompiler="GCC"/>
    </condition>
    <condition id="ARMv8.1-M MVE GCC">
      <description>ARMv8.1-M Mainline + MVE (Cortex-M55) built with GCC.</description>
      <require Dcore="Cortex-M55"/>
      <require Tcompiler="GCC"/>
    </condition>
  </conditions>

  <components>
    <!-- heliaCORE NN — Source variant: build the 200+ kernel sources in-tree. -->
    <component Cclass="Machine Learning" Cgroup="NN Lib" Csub="heliaCORE" Cvariant="Source" Cvendor="Ambiq" Cversion="7.28.0" condition="CMSIS-NN"> <!-- x-release-please-version -->
