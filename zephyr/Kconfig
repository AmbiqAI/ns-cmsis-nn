config ZEPHYR_NS_CMSIS_NN_MODULE
	bool

menuconfig NS_CMSIS_NN
	bool "NS-CMSIS-NN binary package support"
	depends on CPU_CORTEX_M
	depends on !CMSIS_NN
	help
	  Enable the binary-only ns-cmsis-nn Zephyr package.

	  This module links a prebuilt static library selected from the package
	  manifest based on the current Zephyr target and toolchain. The packaged
	  release supports Cortex-M0, Cortex-M4 with FPU, and Cortex-M55 for the
	  gcc, armclang, and llvm-et-arm toolchain families.

	  Unsupported targets or toolchains fail at configure time.
