#
# ns-cmsis-nn CMake package config (per-arch SDK tarball).
#
# Emitted into <pkg>/cmake/ by scripts/build_sdk_tarball.sh with the
# @VAR@ placeholders below substituted for the per-arch build's values.
# Consumers find it via:
#
#   find_package(ns-cmsis-nn REQUIRED PATHS /path/to/extracted-tarball)
#   target_link_libraries(my_app PRIVATE ns::cmsis-nn)
#
# The target graph it exposes (`cmsis-nn`, `ns-cmsis-nn`, `ns::cmsis-nn`)
# matches the source build, so consumer code is build-mode agnostic.

set(NS_CMSIS_NN_VERSION             "@NS_CMSIS_NN_VERSION@")
set(NS_CMSIS_NN_TARGET_CPU          "@NS_CMSIS_NN_TARGET_CPU@")
set(NS_CMSIS_NN_ARCH_FLAGS          "@NS_CMSIS_NN_ARCH_FLAGS@")
set(NS_CMSIS_NN_TOOLCHAIN           "@NS_CMSIS_NN_TOOLCHAIN@")
set(NS_CMSIS_NN_TOOLCHAIN_COMPILER  "@NS_CMSIS_NN_TOOLCHAIN_COMPILER@")

# Capability flags: what this specific archive was actually compiled with.
# These describe archive *contents*, distinct from a consumer's feature
# *request* (NSX's NSX_CMSIS_NN_ENABLE_F32/F16, Zephyr's
# CONFIG_NS_CMSIS_NN_ENABLE_F32/F16). Consumers should validate their
# requests against these before turning ARM_NN_ENABLE_F32/F16 on.
set(NS_CMSIS_NN_HAS_F32                   @NS_CMSIS_NN_HAS_F32@)
set(NS_CMSIS_NN_HAS_F16                   @NS_CMSIS_NN_HAS_F16@)
set(NS_CMSIS_NN_HAS_REQUANTIZE_INLINE_ASM @NS_CMSIS_NN_HAS_REQUANTIZE_INLINE_ASM@)

get_filename_component(_ns_cmsis_nn_root "${CMAKE_CURRENT_LIST_DIR}/.." ABSOLUTE)
set(NS_CMSIS_NN_INCLUDE_DIR "${_ns_cmsis_nn_root}/include")
set(NS_CMSIS_NN_LIBRARY     "${_ns_cmsis_nn_root}/lib/libns-cmsis-nn.a")

if(NOT EXISTS "${NS_CMSIS_NN_LIBRARY}")
  set(${CMAKE_FIND_PACKAGE_NAME}_FOUND FALSE)
  set(${CMAKE_FIND_PACKAGE_NAME}_NOT_FOUND_MESSAGE
    "ns-cmsis-nn package at ${_ns_cmsis_nn_root} is missing lib/libns-cmsis-nn.a")
  return()
endif()
if(NOT IS_DIRECTORY "${NS_CMSIS_NN_INCLUDE_DIR}")
  set(${CMAKE_FIND_PACKAGE_NAME}_FOUND FALSE)
  set(${CMAKE_FIND_PACKAGE_NAME}_NOT_FOUND_MESSAGE
    "ns-cmsis-nn package at ${_ns_cmsis_nn_root} is missing include/")
  return()
endif()

# Soft ABI mismatch check: if the consumer's CMAKE_C_FLAGS specifies
# an -mcpu that contradicts this package's target, fail-fast with a
# clear message rather than letting the linker complain later.
if(CMAKE_C_FLAGS MATCHES "-mcpu=([^ \t]+)")
  set(_ns_cmsis_nn_consumer_cpu "${CMAKE_MATCH_1}")
  if(NOT _ns_cmsis_nn_consumer_cpu STREQUAL "${NS_CMSIS_NN_TARGET_CPU}")
    message(FATAL_ERROR
      "ns-cmsis-nn package is built for ${NS_CMSIS_NN_TARGET_CPU} but "
      "consumer's CMAKE_C_FLAGS specifies -mcpu=${_ns_cmsis_nn_consumer_cpu}. "
      "Download the matching per-arch tarball.")
  endif()
  unset(_ns_cmsis_nn_consumer_cpu)
endif()

# Soft toolchain mismatch check: if the consumer's CMAKE_C_COMPILER_ID is
# known and disagrees with this package's compiler_id, fail-fast. Honours
# the toolchain dimension #177 will expand the publish matrix into.
if(CMAKE_C_COMPILER_ID AND NS_CMSIS_NN_TOOLCHAIN_COMPILER
   AND NOT CMAKE_C_COMPILER_ID STREQUAL NS_CMSIS_NN_TOOLCHAIN_COMPILER)
  message(FATAL_ERROR
    "ns-cmsis-nn package is built with ${NS_CMSIS_NN_TOOLCHAIN_COMPILER} "
    "(toolchain '${NS_CMSIS_NN_TOOLCHAIN}') but the consumer's "
    "CMAKE_C_COMPILER_ID is ${CMAKE_C_COMPILER_ID}. "
    "Download the matching per-toolchain tarball.")
endif()

if(NOT TARGET cmsis-nn)
  add_library(cmsis-nn STATIC IMPORTED GLOBAL)
  set_target_properties(cmsis-nn PROPERTIES
    IMPORTED_LOCATION             "${NS_CMSIS_NN_LIBRARY}"
    INTERFACE_INCLUDE_DIRECTORIES "${NS_CMSIS_NN_INCLUDE_DIR}")
  add_library(ns-cmsis-nn  ALIAS cmsis-nn)
  add_library(ns::cmsis-nn ALIAS cmsis-nn)

  # Auto-expose every float capability this archive was actually compiled
  # with. Unlike NSX/Zephyr (which have pre-existing opt-in toggles this
  # package config has no such API, so the documented policy here is full
  # automatic exposure: if the archive HAS a feature, consumers linking
  # against it get the matching ARM_NN_ENABLE_* macro for free, so the
  # float headers declare what the archive actually implements.
  set(_ns_cmsis_nn_defs "")
  if(NS_CMSIS_NN_HAS_F32)
    list(APPEND _ns_cmsis_nn_defs "ARM_NN_ENABLE_F32=1")
  endif()
  if(NS_CMSIS_NN_HAS_F16)
    list(APPEND _ns_cmsis_nn_defs "ARM_NN_ENABLE_F16=1")
  endif()
  if(_ns_cmsis_nn_defs)
    set_property(TARGET cmsis-nn APPEND PROPERTY
      INTERFACE_COMPILE_DEFINITIONS "${_ns_cmsis_nn_defs}")
  endif()
  unset(_ns_cmsis_nn_defs)
endif()

set(${CMAKE_FIND_PACKAGE_NAME}_FOUND TRUE)
